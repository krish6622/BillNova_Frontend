# BillNova frontend environment (copy to .env.local; gitignored)

# Base URL the SPA uses for API calls. Defaults to same-origin "/api"
# (served via the Vite dev proxy or nginx in Docker).
VITE_API_BASE_URL=/api

# Dev-only: where the Vite proxy forwards /api during `npm run dev`.
VITE_API_PROXY_TARGET=http://localhost:8000
